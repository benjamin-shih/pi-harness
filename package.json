{
  "name": "ben-pi-harness",
  "version": "0.5.0",
  "private": true,
  "keywords": [
    "pi-package"
  ],
  "description": "Benjamin's personal pi harness package: extensions, prompts, and themes.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "verify": "npm run verify:integration",
    "verify:mock": "npm run typecheck && node scripts/verify.mjs",
    "verify:integration": "npm run verify:mock && npm run smoke:pi",
    "verify:full-local": "npm run verify:integration && npm run harness:audit && npm run skills:audit && npm run verify:cross-repo",
    "smoke:pi": "node scripts/pi-lifecycle-smoke.mjs",
    "smoke:user-packages": "node scripts/pi-user-package-smoke.mjs",
    "harness:audit": "node scripts/harness-audit.mjs",
    "skills:audit": "node scripts/skills-audit.mjs",
    "changelog": "node scripts/changelog.mjs",
    "hooks:install": "git config core.hooksPath .githooks",
    "verify:cross-repo": "node scripts/cross-repo-compat.mjs",
    "safe-pi:check": "bash ${AGENTS_SHARED_ROOT:-$HOME/.agents}/scripts/safe-pi.sh --check-only"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.74.0",
    "@types/node": "25.6.0",
    "typescript": "6.0.3"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes"
    ]
  }
}
