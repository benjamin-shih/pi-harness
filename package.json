{
  "name": "ben-pi-harness",
  "version": "0.3.0",
  "private": true,
  "keywords": [
    "pi-package"
  ],
  "description": "Benjamin's personal pi harness package: extensions, prompts, and themes.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "verify": "npm run verify:integration",
    "verify:mock": "npm run typecheck && node scripts/verify.mjs",
    "verify:integration": "npm run verify:mock && npm run smoke:pi",
    "verify:full-local": "npm run verify:integration && npm run harness:audit && npm run skills:audit",
    "smoke:pi": "node scripts/pi-lifecycle-smoke.mjs",
    "harness:audit": "node scripts/harness-audit.mjs",
    "skills:audit": "node scripts/skills-audit.mjs",
    "changelog": "node scripts/changelog.mjs",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "0.71.0",
    "@types/node": "25.6.0",
    "typescript": "6.0.3"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes"
    ]
  }
}
